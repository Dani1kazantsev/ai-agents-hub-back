{
  "$schema": "./registry.schema.json",
  "servers": {
    "jira": {
      "description": "Jira issue tracker integration",
      "server_path": "jira/server.py",
      "env": {
        "JIRA_BASE_URL": {"setting": "JIRA_BASE_URL", "required": true},
        "JIRA_EMAIL": {"setting": "JIRA_EMAIL", "required": true},
        "JIRA_API_TOKEN": {"setting": "JIRA_API_TOKEN", "required": true}
      }
    },
    "gitlab": {
      "description": "GitLab repository integration",
      "server_path": "gitlab/server.py",
      "env": {
        "GITLAB_URL": {"setting": "GITLAB_URL", "required": true},
        "GITLAB_TOKEN": {"setting": "GITLAB_TOKEN", "required": true}
      }
    },
    "docs": {
      "description": "Project documentation from GitLab repository",
      "server_path": "docs/server.py",
      "env": {
        "GITLAB_URL": {"setting": "GITLAB_URL", "required": true},
        "GITLAB_TOKEN": {"setting": "GITLAB_TOKEN", "required": true},
        "DOCS_PROJECT_ID": {"setting": "DOCS_PROJECT_ID", "required": false},
        "PROJECTS_CONFIG_PATH": {"setting": "PROJECTS_CONFIG_PATH", "required": false}
      }
    },
    "db": {
      "description": "Read-only SQL access to external database",
      "server_path": "db/server.py",
      "env": {
        "EXTERNAL_DATABASE_URL": {"setting": "EXTERNAL_DATABASE_URL", "required": true}
      }
    },
    "figma": {
      "description": "Figma design files integration",
      "server_path": "figma/server.py",
      "env": {
        "FIGMA_ACCESS_TOKEN": {"setting": "FIGMA_ACCESS_TOKEN", "required": true}
      }
    }
  }
}
