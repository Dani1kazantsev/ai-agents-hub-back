# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_agent_hub
REDIS_URL=redis://localhost:6379/0

# Auth (OAuth2 provider)
AUTH_PROVIDER_URL=https://your-auth-provider.example.com
AUTH_JWT_SECRET=your-jwt-secret

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# GitLab
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=your-gitlab-private-token

# Figma
FIGMA_ACCESS_TOKEN=your-figma-access-token

# External DB (read-only access for data agent, standard postgresql:// URL)
EXTERNAL_DATABASE_URL=

# MCP servers directory (default: auto-detected from backend root)
MCP_SERVERS_DIR=

# Pencil MCP server command (e.g. "npx @anthropic/pencil-mcp")
PENCIL_MCP_COMMAND=

# Projects config (path to agents/config/projects.json from frontend repo)
PROJECTS_CONFIG_PATH=

# App
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false
